# Dependencies
node_modules/
.pnp
.pnp.js

# Builds
dist/
build/
.next/
out/
*.tsbuildinfo

# Env & secrets — NEVER commit
.env
.env.local
.env.*.local
*.pem
*.key

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editor
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json

# Test / coverage
coverage/

# Screenshots (generated by CI, not committed)
screenshots/

# Playwright MCP artifacts
.playwright-mcp/

# Doc render scratch (PDFs ARE committed as deliverables; preview PNGs are not)
docs/preview/

# Whitepaper content is generated from docs/ via apps/web's prebuild
# script. It IS committed so Vercel (which deploys only apps/web) has
# the inlined markdown. Regenerate locally whenever docs/ changes.

# Root-level screenshot scratch (session artifacts, not deliverables)
/*.png

# Local agent/session databases
smithers.db*

# npm monorepo — stray yarn lockfile
yarn.lock

# Separate contribution workspace, not part of this repo
/midnight-contribution/

# Rendered whitepaper PDFs (regenerable from docs/ sources)
docs/output/*.pdf
