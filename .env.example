# ─── Basilisk environment template ───────────────────────────────────────────
# Copy to `.env` and fill in. NEVER commit real values. (.env is gitignored.)

# ── Cardano data layer (see docs §6) ──
# Ogmios + Kupo — primary chain data (see ADR-001)
# Local Docker (docker compose --profile cardano up -d):
OGMIOS_HOST=localhost
OGMIOS_PORT=1337
KUPO_URL=http://localhost:1442
# Demeter.run managed (alternative — comment out the above, uncomment below):
# OGMIOS_HOST=ogmios.demeter.run
# OGMIOS_PORT=443
# OGMIOS_TLS=true
# KUPO_URL=https://kupo.demeter.run
# DEMETER_API_KEY=

# Blockfrost — REST fallback / cross-check (free tier: 50k req/day)
BLOCKFROST_PROJECT_ID=
BLOCKFROST_NETWORK=mainnet

# ADA/USD oracle source(s)
ADA_USD_ORACLE_PRIMARY=
ADA_USD_ORACLE_SECONDARY=

# ── Datastores ──
# These defaults match docker-compose.yml — just `docker compose up -d db`
DATABASE_URL=postgres://basilisk:basilisk_dev@localhost:5433/basilisk
REDIS_URL=redis://localhost:6379

# ── Auth ──
JWT_SECRET=
SESSION_SECRET=

# ── Notifications ──
RESEND_API_KEY=
TELEGRAM_BOT_TOKEN=
DISCORD_WEBHOOK_URL=

# ── Observability ──
SENTRY_DSN=
GRAFANA_CLOUD_URL=

# ── Service ports (local dev) ──
PORT_API_GATEWAY=4000
PORT_PRICING=4010
PORT_PORTFOLIO=4020
PORT_ALERTS=4030
PORT_NOTIFICATIONS=4040
