{
  "name": "basilisk",
  "version": "0.1.0",
  "private": true,
  "description": "Basilisk \u2014 Cardano on-chain analytics, portfolio & trading platform (monorepo)",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*",
    "docs"
  ],
  "scripts": {
    "build": "npm run build --workspace packages/shared && npm run build --workspace packages/chain-data && npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev:api": "npm run dev --workspace apps/api-gateway",
    "dev:web": "npm run dev --workspace apps/web",
    "db:up": "docker compose up -d db redis",
    "db:down": "docker compose down",
    "db:migrate": "bash db/migrate.sh",
    "docs:pdf": "npm run generate --workspace docs",
    "prepare": "git config core.hooksPath scripts/git-hooks 2>/dev/null || true"
  },
  "engines": {
    "node": ">=20.18.0"
  },
  "dependencies": {
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "license": "MIT"
}